[MITM]
hostname = www.pdreamer.com

[Script]
# 解锁 getUserInfo 会员权益
解锁会员权益 = type=http-response, pattern=^https?://www\.pdreamer\.com/aymyProd/api/getUserInfo, requires-body=true, max-size=0, script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/main/rwmm.js, timeout=60
